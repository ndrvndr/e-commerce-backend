# ==============================================================================
# APPLICATION
# ==============================================================================

APP_NAME=Laravel
APP_ENV=local                   # local | staging | production
APP_KEY=                        # Generate with: php artisan key:generate
APP_DEBUG=true                  # Set to false in production
APP_URL=http://localhost:8000

# Locale
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode driver (file | cache)
APP_MAINTENANCE_DRIVER=file

# Cost factor for bcrypt password hashing (10–12 recommended)
BCRYPT_ROUNDS=12

# ==============================================================================
# LOGGING
# ==============================================================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # debug | info | notice | warning | error | critical

# ==============================================================================
# DATABASE
# ==============================================================================
# Project uses PostgreSQL.
# For managed Postgres, consider Neon (neon.tech) or Supabase (supabase.com).
# Neon connection string format:
#   Host: ep-xxxx.region.aws.neon.tech  |  Port: 5432  |  SSL required
# ==============================================================================

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# ==============================================================================
# SESSION
# ==============================================================================
# SESSION_DRIVER=cookie  → sessions stored in an encrypted cookie (stateless).
#
# SESSION_SECURE_COOKIE  → true requires HTTPS. Set false for local HTTP dev.
# SESSION_SAME_SITE      → Controls cross-site cookie sending:
#   - Lax  : Cookie sent on same-site requests + top-level navigations (default).
#   - None : Cookie sent on ALL cross-site requests; REQUIRES Secure=true.
#   - Strict: Cookie only sent on same-site requests.
# SESSION_HTTP_ONLY      → true prevents JavaScript from reading the cookie (XSS mitigation).
# ==============================================================================

SESSION_DRIVER=cookie
SESSION_LIFETIME=120            # Minutes until session expires
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=false     # true = HTTPS only | false = HTTP allowed (local dev)
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax           # Lax | None | Strict (see notes above)

# ==============================================================================
# QUEUE, CACHE, BROADCAST & FILESYSTEM
# ==============================================================================

BROADCAST_CONNECTION=log        # log | pusher | reverb | ably
FILESYSTEM_DISK=s3              # local | public | s3 (Cloudflare R2 uses s3 driver)
QUEUE_CONNECTION=database       # sync | database | redis | sqs

CACHE_STORE=database            # database | redis | file | array | memcached

# ==============================================================================
# MAIL
# ==============================================================================
# For local development, use "log" mailer to write emails to the log file.
# For production, use smtp | mailgun | ses | postmark | resend etc.
# ==============================================================================

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# FILE STORAGE — Cloudflare R2 (S3-compatible)
# ==============================================================================
# Cloudflare R2 uses the Laravel S3 driver but with a custom endpoint.
#
# How to get credentials:
#   1. Go to Cloudflare Dashboard → R2 → Manage R2 API Tokens
#   2. Create a token with Object Read & Write permissions
#   3. Copy the Access Key ID and Secret Access Key shown at creation time
#   4. Find your bucket endpoint at: R2 → your-bucket → Settings
#
# Variable notes:
#   AWS_ACCESS_KEY_ID        → R2 API Token Access Key ID
#   AWS_SECRET_ACCESS_KEY    → R2 API Token Secret Access Key
#   AWS_DEFAULT_REGION       → Always "auto" for R2
#   AWS_BUCKET               → Your R2 bucket name
#   AWS_USE_PATH_STYLE_ENDPOINT → Must be true for R2
#   AWS_URL                  → Public bucket URL (enable via R2 → Public Access)
#   AWS_ENDPOINT             → Your account's R2 API endpoint:
#                              https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# ==============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=your-r2-bucket-name
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=                        # e.g. https://pub-xxxx.r2.dev (public R2 domain)
AWS_ENDPOINT=                   # e.g. https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ==============================================================================
# VITE
# ==============================================================================

VITE_APP_NAME="${APP_NAME}"

# ==============================================================================
# GOOGLE OAUTH (via Laravel Socialite — stateless + one-time code flow)
# ==============================================================================
# Setup steps at Google Cloud Console (console.cloud.google.com):
#   1. Create a project → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (type: Web application)
#   3. Add Authorized Redirect URIs:
#        Local  : http://localhost:8000/auth/google/callback
#        Prod   : https://your-api-domain.com/auth/google/callback
#   4. Copy the Client ID and Client Secret below.
# ==============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ==============================================================================
# FRONTEND & COOKIE CONFIGURATION
# ==============================================================================
# This section controls how the API communicates with the frontend SPA and how
# the auth_token HTTP-only cookie is scoped.
#
# FRONTEND_URL  → The primary origin of your frontend SPA (used for CORS and
#                 cookie domain resolution). No trailing slash.
#
# FRONTEND_URLS → (Optional) Comma-separated list of additional allowed origins.
#                 Uncomment and use when serving multiple frontends.
#
# COOKIE_DOMAIN → The domain scope for the auth_token cookie:
#   - (empty)            → Cookie is scoped to the current API hostname only.
#   - .yourdomain.com    → Cookie is shared across all subdomains of yourdomain.com
#                          (useful for subdomain-based API + frontend setups).
#
# COOKIE_SECURE → Whether the cookie requires HTTPS:
#   - false → Cookie works over HTTP (use for local development).
#   - true  → Cookie only sent over HTTPS (required for production).
#
# COOKIE_SAME_SITE → Controls cross-site cookie behavior for auth_token:
#   - Lax  → Sent on same-site requests and top-level navigations. Safe default.
#   - None → Sent on ALL cross-origin requests. REQUIRES COOKIE_SECURE=true.
#   - Strict → Only sent on same-site requests (may break OAuth redirects).
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │                    DEPLOYMENT SCENARIO REFERENCE                         │
# ├─────────────────┬────────────────┬───────────────┬───────────────────────┤
# │ Scenario        │ COOKIE_SECURE  │ COOKIE_SAME_  │ COOKIE_DOMAIN         │
# │                 │                │ SITE          │                       │
# ├─────────────────┼────────────────┼───────────────┼───────────────────────┤
# │ Local HTTP      │ false          │ Lax           │ (empty)               │
# │ Same domain     │ true           │ Lax           │ (empty)               │
# │ (api.x.com +    │                │               │                       │
# │  api.x.com SPA) │                │               │                       │
# ├─────────────────┼────────────────┼───────────────┼───────────────────────┤
# │ Subdomain share │ true           │ Lax           │ .yourdomain.com       │
# │ (api.x.com +    │                │               │                       │
# │  app.x.com)     │                │               │                       │
# ├─────────────────┼────────────────┼───────────────┼───────────────────────┤
# │ Cross-domain    │ true           │ None          │ (empty)               │
# │ (api.x.com +    │                │               │                       │
# │  app.y.com)     │                │               │                       │
# └─────────────────┴────────────────┴───────────────┴───────────────────────┘
# ==============================================================================

FRONTEND_URL=http://localhost:3000

# FRONTEND_URLS=http://localhost:3000,http://localhost:4000   # Uncomment for multiple origins

COOKIE_DOMAIN=                  # Empty = current hostname | .domain.com = subdomain sharing
COOKIE_SECURE=false             # false = HTTP (local) | true = HTTPS (production)
COOKIE_SAME_SITE=Lax            # Lax | None | Strict (see table above)

# ==============================================================================
# SANCTUM
# ==============================================================================
# Laravel Sanctum issues API tokens stored in the HTTP-only cookie "auth_token".
#
# SANCTUM_STATEFUL_DOMAINS → Comma-separated list of domains that receive
#   stateful (cookie-based) authentication. Include all frontend origins
#   without the protocol prefix (e.g. localhost:3000, not http://localhost:3000).
#
# SANCTUM_TOKEN_EXPIRATION → Token lifetime in minutes.
#   10080 = 7 days | 43200 = 30 days | null = never expires
# ==============================================================================

SANCTUM_TOKEN_EXPIRATION=10080  # Minutes (10080 = 7 days)
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ==============================================================================
# ADMIN PANEL (Filament 5)
# ==============================================================================
# These credentials are used by the database seeder to create the first
# admin user for the Filament admin panel. Change before running seeders
# in any shared or production environment.
# ==============================================================================

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_seeding

# ==============================================================================
# LIVEWIRE
# ==============================================================================
# Disk and directory used for temporary file uploads in Livewire components.
# "public" disk is recommended for local development.
# ==============================================================================

LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=public
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DIRECTORY=tmp
